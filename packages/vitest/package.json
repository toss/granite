{
  "name": "@granite-js/vitest",
  "version": "1.0.24",
  "type": "module",
  "description": "Vitest helpers for React Native",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toss/granite.git",
    "directory": "packages/vitest"
  },
  "exports": {
    ".": "./dist/index.js",
    "./reactNativeRuntime": "./dist/reactNativeRuntime.js",
    "./setup": "./dist/setup.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepack": "yarn build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest --run",
    "build": "tsdown"
  },
  "dependencies": {
    "flow-remove-types": "2.291.0"
  },
  "devDependencies": {
    "@types/node": "catalog:tools",
    "@types/react": "catalog:react-native",
    "react": "catalog:react-native",
    "react-native": "catalog:react-native",
    "tsdown": "catalog:tools",
    "typescript": "catalog:tools",
    "vitest": "4.1.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "vitest": "*"
  },
  "sideEffects": [
    "./dist/reactNativeRuntime.js",
    "./dist/setup.js"
  ]
}
