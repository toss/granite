# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "brick-module/podfile_helper.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

def patch_brick_codegen_podspec!(app_path)
  podspec_path = File.join(app_path, 'ios/.brick/BrickCodegen.podspec')
  return unless File.exist?(podspec_path)

  content = File.read(podspec_path)
  content = content.gsub(
    's.source_files = "**/*.{h,m,mm,swift}", "Types/**/*.swift"',
    's.source_files = "Brick*.{h,m,mm,swift}", "ReactCodegen/BrickModuleSpec/**/*.{h,m,mm}", "ReactCodegen/BrickModuleSpecJSI.h"'
  )
  File.write(podspec_path, content)
end

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target '%%nativeAppName%%' do
  app_path = "#{Pod::Config.instance.installation_root}/.."

  ENV['GRANITE_IMAGE_DEFAULT_PROVIDER'] ||= 'false'

  use_brick_modules!(app_path: app_path)
  patch_brick_codegen_podspec!(app_path)
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => app_path
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
